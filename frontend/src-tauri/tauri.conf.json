{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "OpenGG",
  "version": "1.0.0",
  "identifier": "org.opengg.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenGG",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"]
        }
      }
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "rpm"],
    "icon": ["icons/32x32.png", "icons/128x128.png"],
    "linux": {
      "deb": { "depends": ["pipewire", "wireplumber", "ffmpeg"] }
    }
  }
}
